---
interface Props {
  title: string;
  description: string;
  date: string;
  tags: string[];
  readingTime: string;
  href: string;
}

const { title, description, date, tags, readingTime, href } = Astro.props;

const formatted = new Date(date).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={href}
  class="group block rounded-2xl border border-white/[0.08] bg-white/[0.04] p-6 hover:border-indigo-500/50 hover:shadow-[0_0_35px_rgba(99,102,241,0.1)] transition-all duration-300"
>
  <!-- Meta row -->
  <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
    <span>{formatted}</span>
    <span>·</span>
    <span>{readingTime}</span>
  </div>

  <!-- Title -->
  <h3 class="font-display font-bold text-lg text-slate-100 leading-snug mb-2 group-hover:text-indigo-300 transition-colors duration-200">
    {title}
  </h3>

  <!-- Description -->
  <p class="text-slate-400 text-sm leading-[1.75] mb-4 line-clamp-2">
    {description}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-300 border border-indigo-500/20">
        {tag}
      </span>
    ))}
  </div>
</a>
