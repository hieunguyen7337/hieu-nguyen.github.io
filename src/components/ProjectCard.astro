---
import type { Project } from '../data/projects';
import { asset } from '../utils/asset';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const badgeClasses: Record<string, string> = {
  cyan:   'bg-cyan-500/20 text-cyan-300 border-cyan-500/40',
  indigo: 'bg-indigo-500/20 text-indigo-300 border-indigo-500/40',
  teal:   'bg-teal-500/20 text-teal-300 border-teal-500/40',
  gold:   'bg-amber-500/15 text-amber-300 border-amber-500/35',
};

const allImages = project.galleryImages?.length
  ? project.galleryImages.map((img) => asset(img))
  : project.primaryImage
  ? [asset(project.primaryImage)]
  : [];
const galleryJson = JSON.stringify(allImages);
---

<article
  class="group rounded-2xl overflow-hidden border border-white/[0.08] bg-white/[0.04] hover:border-indigo-500/50 hover:shadow-[0_0_35px_rgba(99,102,241,0.1)] transition-all duration-300 flex flex-col"
>
  <!-- Image -->
  <div
    class="card-gallery-trigger relative overflow-hidden"
    style="aspect-ratio: 16/9; cursor: pointer;"
    data-gallery={galleryJson}
    aria-label={`View images for ${project.title}`}
  >
    {
      project.primaryImage ? (
        <img
          src={asset(project.primaryImage)}
          alt={project.title}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.06]"
        />
      ) : (
        <div class="w-full h-full flex flex-col items-center justify-center gap-2 bg-gradient-to-br from-indigo-500/10 to-cyan-500/10">
          <svg width="30" height="30" fill="none" stroke="rgba(148,163,184,0.4)" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-slate-600 text-xs">No preview</span>
        </div>
      )
    }
    <div class="absolute inset-0 bg-black/0 hover:bg-black/25 transition-colors duration-300 flex items-center justify-center">
      <svg class="opacity-0 group-hover:opacity-80 transition-opacity duration-300 drop-shadow-lg" width="28" height="28" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
      </svg>
    </div>
  </div>

  <!-- Body -->
  <div class="p-5 flex flex-col gap-2 flex-1">
    {
      project.badge && (
        <span
          class={`self-start px-2.5 py-0.5 rounded-full text-[11px] font-semibold border ${badgeClasses[project.badge.color]}`}
        >
          {project.badge.label}
        </span>
      )
    }
    <div class="flex flex-wrap gap-1.5">
      {
        project.tags.slice(0, 3).map((tag) => (
          <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-300 border border-indigo-500/20">
            {tag}
          </span>
        ))
      }
    </div>
    <h3 class="font-display font-bold text-[0.95rem] text-slate-100 leading-snug mt-1">
      {project.title}
    </h3>
    <p class="text-slate-400 text-sm leading-[1.75] flex-1">
      {project.description}
    </p>
  </div>
</article>
