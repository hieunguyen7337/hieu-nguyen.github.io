---
import type { ExperienceEntry } from '../data/experience';
import { asset } from '../utils/asset';

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;

const hasPhotos = (entry.photoStrip?.length ?? 0) > 0;
const photoGalleryJson = hasPhotos
  ? JSON.stringify(entry.photoStrip!.map((p) => asset(p.src)))
  : '';
---

<div class="timeline-item relative pl-8 mb-7 last:mb-0">
  <!-- Dot -->
  <div
    class="timeline-dot absolute left-[-1.35rem] top-6 w-3.5 h-3.5 rounded-full bg-indigo-500 border-[3px] border-[#08090f] shadow-[0_0_12px_rgba(99,102,241,0.6)] transition-all duration-300"
  ></div>

  <div
    class="border border-white/[0.08] bg-white/[0.04] rounded-2xl p-6 hover:border-indigo-500/25 hover:translate-x-1 transition-all duration-300"
  >
    <div class="flex flex-wrap justify-between gap-3 mb-3">
      <div>
        <h3 class="font-display font-bold text-[1.1rem] text-slate-100 mb-1">
          {entry.company}
        </h3>
        {
          entry.roles.map((role) => (
            <div class="text-sm">
              <span class="text-cyan-400 font-medium">{role.title}</span>
              <span class="text-slate-500 ml-2">· {role.period}</span>
            </div>
          ))
        }
      </div>
      <span class="text-slate-500 text-sm self-start mt-0.5">{entry.location}</span>
    </div>

    <p class="text-slate-400 text-sm leading-[1.8]">{entry.description}</p>

    {
      entry.links?.length && (
        <div class="flex flex-wrap gap-1.5 mt-3">
          {entry.links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-[11px] px-2.5 py-1 rounded-full border border-slate-600/50 bg-white/[0.04] text-slate-300 hover:border-cyan-500/50 hover:text-cyan-300 transition-all duration-200"
            >
              <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              {link.label}
            </a>
          ))}
        </div>
      )
    }

    {
      hasPhotos && (
        <div class="photo-strip flex gap-2 overflow-x-auto mt-4 pb-1">
          {entry.photoStrip!.map((photo, i) => (
            <img
              src={asset(photo.src)}
              alt={photo.alt}
              loading="lazy"
              data-gallery={photoGalleryJson}
              data-index={i}
              class="gallery-strip-img h-[90px] w-auto object-cover rounded-lg flex-shrink-0 cursor-pointer hover:opacity-80 transition-opacity border border-white/[0.06]"
            />
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .timeline-item:hover .timeline-dot {
    transform: scale(1.35);
    background: #06b6d4;
    box-shadow: 0 0 14px rgba(6, 182, 212, 0.7);
  }
</style>
