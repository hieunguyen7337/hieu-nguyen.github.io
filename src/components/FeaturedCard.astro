---
import type { Project } from '../data/projects';
import { asset } from '../utils/asset';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const badgeClasses: Record<string, string> = {
  cyan:   'bg-cyan-500/20 text-cyan-300 border-cyan-500/40',
  indigo: 'bg-indigo-500/20 text-indigo-300 border-indigo-500/40',
  teal:   'bg-teal-500/20 text-teal-300 border-teal-500/40',
  gold:   'bg-amber-500/15 text-amber-300 border-amber-500/35',
};

const allImages = project.galleryImages?.length
  ? project.galleryImages.map((img) => asset(img))
  : project.primaryImage
  ? [asset(project.primaryImage)]
  : [];
const galleryJson = JSON.stringify(allImages);
---

<article class="featured-card group">
  <!-- Image column -->
  <div
    class="featured-img-wrap card-gallery-trigger"
    data-gallery={galleryJson}
    style="cursor: pointer;"
    aria-label={`View images for ${project.title}`}
  >
    {
      project.primaryImage ? (
        <img
          src={asset(project.primaryImage)}
          alt={project.title}
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-indigo-500/10 to-cyan-500/10">
          <span class="text-slate-600 text-sm">No preview</span>
        </div>
      )
    }
    <!-- Expand hint on hover -->
    <div class="absolute inset-0 bg-black/0 hover:bg-black/25 transition-colors duration-300 flex items-center justify-center">
      <svg class="opacity-0 group-hover:opacity-80 transition-opacity duration-300 drop-shadow-lg" width="36" height="36" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
      </svg>
    </div>
  </div>

  <!-- Text column -->
  <div class="featured-body">
    {
      project.badge && (
        <span
          class={`self-start mb-3 px-3 py-1 rounded-full text-xs font-semibold border ${badgeClasses[project.badge.color]}`}
        >
          {project.badge.label}
        </span>
      )
    }
    <div class="flex flex-wrap gap-2 mb-4">
      {
        project.tags.map((tag) => (
          <span class="text-xs px-3 py-1 rounded-full bg-indigo-500/10 text-indigo-300 border border-indigo-500/20">
            {tag}
          </span>
        ))
      }
    </div>
    <h3 class="font-display font-bold text-xl text-slate-100 mb-3 leading-snug">
      {project.title}
    </h3>
    <p class="text-slate-400 text-[0.95rem] leading-[1.8] flex-1">
      {project.description}
    </p>
    {
      project.links?.length && (
        <div class="flex flex-wrap gap-2 mt-5">
          {project.links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full border border-slate-600/50 bg-white/[0.04] text-slate-300 hover:border-cyan-500/50 hover:text-cyan-300 transition-all duration-200"
            >
              <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .featured-card {
    display: grid;
    grid-template-columns: 3fr 2fr;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: border-color 0.3s, box-shadow 0.3s;
    min-height: 260px;
  }
  .featured-card:hover {
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow: 0 0 50px rgba(99, 102, 241, 0.1);
  }
  .featured-img-wrap {
    position: relative;
    overflow: hidden;
  }
  .featured-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .featured-card {
      grid-template-columns: 1fr;
    }
    .featured-img-wrap {
      aspect-ratio: 16 / 9;
    }
  }
</style>
