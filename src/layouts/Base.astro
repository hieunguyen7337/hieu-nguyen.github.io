---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Hieu Nguyen | AI Engineer',
  description =
    'Portfolio of Hieu Nguyen, AI Engineer specialising in LLMs, computer vision, and production ML systems. Based in Brisbane, Australia.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#08090f] text-slate-100 font-sans antialiased min-h-screen">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 76px;
  }

  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #08090f; }
  ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #334155; }

  .section-title {
    font-family: 'Outfit', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .section-title::after {
    content: '';
    height: 1px;
    flex: 1;
    background: linear-gradient(to right, rgba(99, 102, 241, 0.4), transparent);
  }

  /* Timeline vertical rule */
  .timeline-wrap {
    position: relative;
    padding-left: 1.5rem;
  }
  .timeline-wrap::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 28px;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #6366f1, rgba(6, 182, 212, 0.3), transparent);
  }

  /* Nav scrolled shadow */
  #navbar.scrolled {
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.6);
  }

  /* Animated gradient ring */
  @keyframes spin-ring {
    to { transform: rotate(360deg); }
  }

  /* Photo strip scrollbar */
  .photo-strip::-webkit-scrollbar { height: 3px; }
  .photo-strip::-webkit-scrollbar-thumb { background: #334155; border-radius: 2px; }

  /* ── Blog prose typography ───────────────────────────────────────── */
  .prose-blog { color: #94a3b8; font-size: 1.05rem; line-height: 1.85; }

  .prose-blog p { margin-bottom: 1.4rem; }

  .prose-blog h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-top: 2.8rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .prose-blog h2::after {
    content: '';
    height: 1px;
    flex: 1;
    background: linear-gradient(to right, rgba(99, 102, 241, 0.4), transparent);
  }

  .prose-blog h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #cbd5e1;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
  }

  .prose-blog strong { color: #e2e8f0; font-weight: 600; }
  .prose-blog em { color: #94a3b8; }

  .prose-blog a { color: #22d3ee; text-decoration: none; }
  .prose-blog a:hover { color: #67e8f9; text-decoration: underline; }

  .prose-blog ul, .prose-blog ol {
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }
  .prose-blog li { margin-bottom: 0.4rem; }
  .prose-blog ul li { list-style: disc; }
  .prose-blog ol li { list-style: decimal; }

  .prose-blog blockquote {
    border-left: 3px solid rgba(99, 102, 241, 0.5);
    padding: 0.6rem 0 0.6rem 1.2rem;
    margin: 1.4rem 0;
    color: #94a3b8;
    font-style: italic;
  }

  .prose-blog code {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-size: 0.875em;
    color: #e2e8f0;
    font-family: 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
  }

  .prose-blog pre {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 1.2rem 1.4rem;
    overflow-x: auto;
    margin-bottom: 1.4rem;
  }
  .prose-blog pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: #cbd5e1;
  }

  .prose-blog table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.4rem;
    font-size: 0.9rem;
  }
  .prose-blog th {
    background: rgba(255,255,255,0.06);
    color: #e2e8f0;
    font-weight: 600;
    text-align: left;
    padding: 0.6rem 0.9rem;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .prose-blog td {
    padding: 0.55rem 0.9rem;
    border: 1px solid rgba(255,255,255,0.06);
    color: #94a3b8;
    vertical-align: top;
  }
  .prose-blog tr:nth-child(even) td { background: rgba(255,255,255,0.02); }

  .prose-blog hr {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin: 2.5rem 0;
  }
</style>
